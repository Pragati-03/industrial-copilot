# Application
APP_NAME="Industrial Knowledge Intelligence API"
APP_ENV=development
DEBUG=true

# API
API_V1_PREFIX=/api/v1

# CORS - comma separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
DATABASE_URL=sqlite:///./industrial_ki.db

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.webp,.gif,.docx,.txt
 TESSERACT_CMD=